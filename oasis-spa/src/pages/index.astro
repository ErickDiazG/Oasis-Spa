			document.addEventListener("DOMContentLoaded", () => {
				const langBtn = document.querySelector(".lang-btn");
				const langMenu = document.querySelector(".lang-menu");
				const arrow = document.querySelector(".arrow") as HTMLElement;
				const langLinks = document.querySelectorAll(".lang-menu a");
				const currentLangLabel = document.getElementById("current-lang");

				const applyLanguage = (lang: string) => {
					localStorage.setItem("oasis_lang", lang);
					if (!translations[lang]) return;
					document.querySelectorAll("[data-i18n]").forEach((el) => {
						const key = el.getAttribute("data-i18n");
						if (key && translations[lang][key]) { el.innerHTML = translations[lang][key]; }
					});
					document.querySelectorAll("[data-i18n-placeholder]").forEach((el) => {
						const key = el.getAttribute("data-i18n-placeholder");
						if (key && translations[lang][key]) { el.setAttribute("placeholder", translations[lang][key]); }
					});
					if (currentLangLabel) { currentLangLabel.textContent = lang.toUpperCase(); }
					const selectedFlag = document.getElementById("selected-flag") as HTMLImageElement;
					if (selectedFlag) {
						selectedFlag.src = lang === "es" ? "https://flagcdn.com/w40/mx.png" : "https://flagcdn.com/w40/us.png";
						selectedFlag.alt = lang.toUpperCase() + " Flag";
					}
				};

				if (langBtn && langMenu && arrow) {
					langBtn.addEventListener("click", (e) => {
						e.stopPropagation();
						const isExpanded = langMenu.classList.toggle("show");
						langBtn.setAttribute("aria-expanded", String(isExpanded));
						arrow.style.transform = isExpanded ? "rotate(180deg)" : "rotate(0)";
					});
					document.addEventListener("click", () => {
						if (langMenu.classList.contains("show")) {
							langMenu.classList.remove("show");
							langBtn.setAttribute("aria-expanded", "false");
							arrow.style.transform = "rotate(0)";
						}
					});
					langLinks.forEach((link) => {
						link.addEventListener("click", (e) => {
							e.preventDefault();
							const selectedLang = (e.target as HTMLElement).getAttribute("data-lang");
							if (selectedLang) { applyLanguage(selectedLang); }
							langMenu.classList.remove("show");
							langBtn.setAttribute("aria-expanded", "false");
							arrow.style.transform = "rotate(0)";
						});
					});
				}

				// Testimonial Carousel
				let currentIndex = 0;
				const track = document.querySelector(".testim-track") as HTMLElement;
				const testimCards = document.querySelectorAll(".testim-track .testimonial-card");
				const prevBtn = document.querySelector(".testim-btn.prev");
				const nextBtn = document.querySelector(".testim-btn.next");
				if (track && testimCards.length && prevBtn && nextBtn) {
					const updateCarousel = () => { track.style.transform = `translateX(-${currentIndex * 100}%)`; };
					nextBtn.addEventListener("click", () => { currentIndex = (currentIndex + 1) % testimCards.length; updateCarousel(); });
					prevBtn.addEventListener("click", () => { currentIndex = (currentIndex - 1 + testimCards.length) % testimCards.length; updateCarousel(); });
				}

				// Dynamic Navbar Scroll (Mobile)
				const navbar = document.querySelector(".navbar");
				window.addEventListener("scroll", () => {
					if (window.innerWidth <= 768) {
						if (window.scrollY > 60) { navbar?.classList.add("nav-scrolled"); }
						else { navbar?.classList.remove("nav-scrolled"); }
					}
				});

				// Form Submission
				const bookingSubmitBtn = document.getElementById("booking-submit");
				const bookingName = document.getElementById("booking-name") as HTMLInputElement;
				const bookingEmail = document.getElementById("booking-email") as HTMLInputElement;
				const bookingPhone = document.getElementById("booking-phone") as HTMLInputElement;
				const bookingService = document.getElementById("booking-service") as HTMLSelectElement;
				if (bookingSubmitBtn) {
					bookingSubmitBtn.addEventListener("click", () => {
						const nameValue = bookingName.value.trim();
						const serviceValue = bookingService.options[bookingService.selectedIndex].text;
						const emailValue = bookingEmail.value.trim();
						const phoneValue = bookingPhone.value.trim();
						const lang = localStorage.getItem("oasis_lang") || "es";
						if (!nameValue || bookingService.value === "") { alert(translations[lang].form_error); return; }
						const intro = translations[lang].wa_form_intro.replace("[nombre]", nameValue);
						let contactInfo = "";
						if (emailValue || phoneValue) {
							contactInfo = `\n\n${translations[lang].wa_form_contact}`;
							if (emailValue) contactInfo += `\n- Email: ${emailValue}`;
							if (phoneValue) contactInfo += `\n- Tel: ${phoneValue}`;
						}
						const message = `${intro}\n\n- ${serviceValue}${contactInfo}`;
						const waNumber = "523223626879";
						window.open(`https://wa.me/${waNumber}?text=${encodeURIComponent(message)}`, "_blank");
					});
				}

				const savedLang = localStorage.getItem("oasis_lang") || "es";
				applyLanguage(savedLang);
			});
		</script>
	</body>
