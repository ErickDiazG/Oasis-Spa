<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link
			rel="icon"
			type="image/png"
			sizes="32x32"
			href="/favicon-32x32.png"
		/>
		<link
			rel="icon"
			type="image/png"
			sizes="16x16"
			href="/favicon-16x16.png"
		/>
		<link
			rel="apple-touch-icon"
			sizes="180x180"
			href="/apple-touch-icon.png"
		/>
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<title>Oasis Massage & Spa | Tu Refugio de Bienestar</title>
		<link
			href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<!-- Navbar -->
		<nav class="navbar">
			<div class="nav-container">
				<div class="logo">
					<img
						src="/logo-oasis.png"
						alt="Oasis Massage & Spa Logo"
						class="nav-logo-img"
					/>
				</div>
				<ul class="nav-links">
					<li>
						<a href="#servicios" data-i18n="nav_services"
							>Servicios</a
						>
					</li>
					<li>
						<a href="#instalaciones" data-i18n="nav_facilities"
							>Instalaciones</a
						>
					</li>
					<li>
						<a href="#contacto" data-i18n="nav_contact">Contacto</a>
					</li>
					<li><a href="#faq" data-i18n="nav_faq">FAQ</a></li>
				</ul>
				<div class="nav-actions">
					<div class="lang-selector">
						<button
							class="lang-btn"
							aria-haspopup="true"
							aria-expanded="false"
						>
							<img
								id="selected-flag"
								src="https://flagcdn.com/w40/mx.png"
								alt="ES Flag"
								class="nav-flag"
							/>
							<span id="current-lang">ES</span>
							<span class="arrow">▼</span>
						</button>
						<ul class="lang-menu">
							<li><a href="#" data-lang="es">
								<img src="https://flagcdn.com/w40/mx.png" alt="ES" class="nav-flag" />
								Español
							</a></li>
							<li><a href="#" data-lang="en">
								<img src="https://flagcdn.com/w40/us.png" alt="EN" class="nav-flag" />
								English
							</a></li>
						</ul>
					</div>
					<a href="#contacto" class="btn-primary" data-i18n="btn_book"
						>Reservar</a
					>
				</div>
			</div>
		</nav>

		<!-- Hero -->
		<header class="hero" id="hero">
			<div class="hero-overlay"></div>
			<div class="hero-content">
				<img
					src="/logo-oasis.png"
					alt="Oasis Massage & Spa Logo"
					class="hero-logo-img"
				/>
				<h1 data-i18n="hero_title">
					Tu oasis de relajación en <br />
					<em>Cruz de Huanacaxtle</em>
				</h1>
				<p data-i18n="hero_subtitle">
					Un refugio exclusivo para tu cuerpo, mente y alma.
					Vive la experiencia de nuestros masajes y tratamientos premium.
				</p>
				<div class="hero-actions">
					<a
						href="#servicios"
						class="btn-primary"
						data-i18n="hero_btn_explore">Explorar Servicios</a
					>
					<a
						href="#contacto"
						class="btn-outline"
						data-i18n="hero_btn_contact">Contáctanos</a
					>
				</div>
			</div>
		</header>

		<!-- Servicios Principales -->
		<section class="section bg-light" id="servicios">
			<div class="container text-center">
				<h2 class="section-title" data-i18n="srv_title">
					Nuestros Servicios
				</h2>
				<p class="section-subtitle" data-i18n="srv_subtitle">
					Rituales de bienestar diseñados para desconectar del estrés
					diario.
				</p>
				<div class="grid services-grid">
					<div class="card service-card">
						<img src="/images/masaje%20relajante.webp" alt="Masajes Relajantes" />
						<div class="card-content">
							<h3 data-i18n="srv_relax_title">Masajes Relajantes</h3>
							<p data-i18n="srv_relax_desc" style="margin-bottom: 1.5rem;">Terapia de cuerpo completo con aceites esenciales puros y técnicas suecas para liberar tensión y revitalizar tu cuerpo.</p>
							<a href="#contacto" class="btn-outline-primary" data-i18n="book_now">Reservar ahora</a>
						</div>
					</div>
					<div class="card service-card">
						<img src="/images/masaje%20profundo.webp" alt="Masajes Terapéuticos" />
						<div class="card-content">
							<h3 data-i18n="srv_therapeutic_title">Masajes Terapéuticos</h3>
							<p data-i18n="srv_therapeutic_desc" style="margin-bottom: 1.5rem;">Técnicas especializadas que alivian dolores musculares, mejoran la circulación y restauran tu bienestar físico.</p>
							<a href="#contacto" class="btn-outline-primary" data-i18n="book_now">Reservar ahora</a>
						</div>
					</div>
					<div class="card service-card">
						<img src="/images/masaje-facial.webp" alt="Deep Tissue" />
						<div class="card-content">
							<h3 data-i18n="srv_deep_title">Masaje de Tejido Profundo</h3>
							<p data-i18n="srv_deep_desc" style="margin-bottom: 1.5rem;">Presión profunda que libera tensiones crónicas y nudos musculares para un alivio duradero.</p>
							<a href="#contacto" class="btn-outline-primary" data-i18n="book_now">Reservar ahora</a>
						</div>
					</div>
					<div class="card service-card">
						<img src="/images/facial-rejuvenecedor.webp" alt="Faciales Premium" />
						<div class="card-content">
							<h3 data-i18n="srv_facial_title">Faciales Premium</h3>
							<p data-i18n="srv_facial_desc" style="margin-bottom: 1.5rem;">Tratamientos avanzados que restauran firmeza y luminosidad, reduciendo signos del tiempo con ingredientes de primera.</p>
							<a href="#contacto" class="btn-outline-primary" data-i18n="book_now">Reservar ahora</a>
						</div>
					</div>
				</div>
				<div class="mt-4" style="margin-top: 3rem;">
					<a
						href="/servicios"
						class="btn-primary"
						data-i18n="view_all_services">Ver todos los servicios</a
					>
				</div>
			</div>
		</section>

		<!-- Instalaciones -->
		<section class="section bg-dark" id="instalaciones">
			<div class="container container-flex">
				<div class="flex-half fade-in">
					<h2 class="section-title" data-i18n="fac_title">
						Nuestras Instalaciones
					</h2>
					<p data-i18n="fac_desc">
						Hemos cuidado cada detalle para crear un ambiente donde el tiempo se detiene.
					</p>
					<ul class="features-list">
						<li data-i18n="fac_feat1">
							✓ Ambiente zen
						</li>
						<li data-i18n="fac_feat2">
							✓ Té de cortesía
						</li>
						<li data-i18n="fac_feat3">
							✓ Manos Expertas
						</li>
					</ul>
				</div>
				<div class="flex-half img-box">
					<img
						src="/images/spa-instalaciones.webp"
						alt="Instalaciones del spa"
						class="rounded-img shadow"
					/>
				</div>
			</div>
		</section>

		<!-- Galería -->
		<section class="section bg-light" id="galeria">
			<div class="container text-center">
				<h2 class="section-title" data-i18n="gal_title">
					Galería de Paz
				</h2>
				<p class="section-subtitle" data-i18n="gal_subtitle">
					Un vistazo a los espacios que hemos creado para tu
					bienestar.
				</p>
				<div class="gallery-carousel-wrapper">
					<div class="gallery-carousel-track">
						<img
							src="/images/spa_gallery.png"
							alt="Galería 1"
							class="gallery-img"
						/>
						<img
							src="/images/spa_facilities.png"
							alt="Galería 2"
							class="gallery-img"
						/>
						<img
							src="/images/spa_massage.png"
							alt="Galería 3"
							class="gallery-img"
						/>
						<img
							src="/images/spa_facial.png"
							alt="Galería 4"
							class="gallery-img"
						/>
						<!-- Duplicado para crear el loop infinito -->
						<img
							src="/images/spa_gallery.png"
							alt="Galería 1"
							class="gallery-img"
						/>
						<img
							src="/images/spa_facilities.png"
							alt="Galería 2"
							class="gallery-img"
						/>
						<img
							src="/images/spa_massage.png"
							alt="Galería 3"
							class="gallery-img"
						/>
						<img
							src="/images/spa_facial.png"
							alt="Galería 4"
							class="gallery-img"
						/>
					</div>
				</div>
			</div>
		</section>

		<!-- Testimonios -->
		<section class="section bg-primary text-white" id="testimonios">
			<div class="container text-center">
				<h2 class="section-title text-white" data-i18n="testim_title">
					Lo que dicen nuestros clientes
				</h2>
				<div class="testimonials-carousel" id="testim-carousel">
					<div class="testim-track">
						<div class="testimonial-card">
							<div class="stars">★★★★★</div>
							<p class="quote" data-i18n="testim_1">"El mejor masaje que me han dado en mi vida. El ambiente es increíble y salí completamente renovada. ¡100% recomendado!"</p>
							<span class="author">- Laura M.</span>
						</div>
						<div class="testimonial-card">
							<div class="stars">★★★★★</div>
							<p class="quote" data-i18n="testim_2">"Increíble experiencia. El masaje de tejido profundo me quitó todo el estrés acumulado. El personal es muy profesional y atento."</p>
							<span class="author">- Carlos R.</span>
						</div>
						<div class="testimonial-card">
							<div class="stars">★★★★★</div>
							<p class="quote" data-i18n="testim_3">"Un oasis de paz en Cruz de Huanacaxtle. Los paquetes de spa son una maravilla, incluyendo snacks y vino. Volveremos sin duda."</p>
							<span class="author">- Jennifer W.</span>
						</div>
						<div class="testimonial-card">
							<div class="stars">★★★★★</div>
							<p class="quote" data-i18n="testim_4">"Los faciales premium son de otro nivel. Mi piel quedó radiante y el trato fue exquisito. ¡Un lugar que vale cada peso!"</p>
							<span class="author">- Ana P.</span>
						</div>
						<div class="testimonial-card">
							<div class="stars">★★★★★</div>
							<p class="quote" data-i18n="testim_5">"Fui con mi pareja y fue una experiencia magnífica. El ambiente, la atención y los masajes fueron de primera calidad."</p>
							<span class="author">- David & Sophie</span>
						</div>
						<div class="testimonial-card">
							<div class="stars">★★★★★</div>
							<p class="quote" data-i18n="testim_6">"El paquete Harmony fue increíble. Salí como nueva. Sin duda el mejor spa de la zona. Las chicas son muy profesionales."</p>
							<span class="author">- Martha G.</span>
						</div>
					</div>
					<div class="testim-controls">
						<button class="testim-btn prev">❮</button>
						<button class="testim-btn next">❯</button>
					</div>
				</div>
			</div>
		</section>

		<!-- Contacto, Horarios y Redes -->
		<section class="section bg-dark" id="contacto">
			<div class="container">
				<div class="grid contact-grid">
					<!-- Formulario -->
					<div class="contact-form-box card">
						<h3 data-i18n="contact_form_title">
							Reserva tu momento
						</h3>
						<form class="booking-form" id="booking-form">
							<input
								id="booking-name"
								type="text"
								placeholder="Tu Nombre completo"
								data-i18n-placeholder="form_name"
								required
							/>
							<input
								id="booking-email"
								type="email"
								placeholder="Correo Electrónico"
								data-i18n-placeholder="form_email"
							/>
							<input
								id="booking-phone"
								type="tel"
								placeholder="Teléfono"
								data-i18n-placeholder="form_phone"
							/>
							<select id="booking-service" required>
								<option value="" data-i18n="form_service_select">Selecciona un Servicio</option>
								<option value="Masaje Relajante" data-i18n="srv_relax_title">Masajes Relajantes</option>
								<option value="Masaje Terapéutico" data-i18n="srv_therapeutic_title">Masajes Terapéuticos</option>
								<option value="Tejido Profundo" data-i18n="srv_deep_title">Masaje de Tejido Profundo</option>
								<option value="Facial Premium" data-i18n="srv_facial_title">Faciales Premium</option>
							</select>
							<button
								id="booking-submit"
								type="button"
								class="btn-primary w-full mt-4"
								data-i18n="form_btn">Solicitar Reserva</button
							>
						</form>
					</div>

					<!-- Horarios y Redes -->
					<div class="contact-info fade-in">
						<h2
							class="section-title"
							data-i18n="contact_info_title"
						>
							Te estamos esperando
						</h2>

						<div class="info-block">
							<h4 data-i18n="hours_title">Horarios de Atención</h4>
							<p data-i18n="hours_1">Lunes a Sábado: 10 a.m. – 6 p.m.</p>
							<p data-i18n="hours_2">Domingo: Cerrado</p>
						</div>

						<div class="info-block mt-4">
							<h4 data-i18n="contact_title">Contacto y Redes Sociales</h4>
							<p data-i18n="contact_phone">Teléfono: 322 362 6879</p>
							<div class="social-links mt-2">
								<a href="https://www.facebook.com/oasisspalacruz" target="_blank" class="social-icon">Facebook</a>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Mapa -->
		<section class="section map-section bg-light" id="mapa">
			<div class="container text-center mb-5">
				<h2 class="section-title" data-i18n="map_title">
					Encuéntranos
				</h2>
				<p class="section-subtitle" data-i18n="map_desc">
					Visítanos en nuestra ubicación privilegiada en Bucerías
				</p>
			</div>
			
			<div class="container px-4">
				<div class="map-wrapper shadow">
					<iframe
						src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3732.5!2d-105.38!3d20.75!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMjDCsDQ1JzAwLjAiTiAxMDXCsDIyJzQ4LjAiVw!5e0!3m2!1ses!2smx!4v1680000000000"
						width="100%"
						height="100%"
						style="border:0;"
						allowfullscreen=""
						loading="lazy"
						referrerpolicy="no-referrer-when-downgrade"
					></iframe>
					
					<div class="map-info-card">
						<h3 class="mb-3" style="color: var(--color-primary); font-family: 'Playfair Display', serif;">Cruz de Huanacaxtle, Nay.</h3>
						<p class="mb-4" style="color: #666; font-size: 0.95rem; line-height: 1.6;">
							Coral 6, entre Huachinango y Pescador,<br>
							Mesa Quemada, 63734<br>
							Cruz de Huanacaxtle, Nayarit
						</p>
						<a href="https://maps.app.goo.gl/4a2vKBdNsJY3rkyNA" target="_blank" class="btn-outline-primary w-100 text-center" data-i18n="view_on_maps">
							Ver en Google Maps
						</a>
					</div>
				</div>
			</div>
		</section>

		<!-- FAQ -->
		<section class="section bg-dark" id="faq">
			<div class="container">
				<h2 class="section-title text-center" data-i18n="faq_title">
					Preguntas Frecuentes
				</h2>
				<div class="faq-list">
					<details class="faq-item">
						<summary data-i18n="faq_q1"
							>¿Con cuánto tiempo de anticipación debo reservar?</summary
						>
						<p data-i18n="faq_a1">
							Recomendamos realizar su reserva con al menos 48
							horas de anticipación para asegurar disponibilidad.
						</p>
					</details>
					<details class="faq-item">
						<summary data-i18n="faq_q2"
							>¿Qué debo llevar a mi cita?</summary
						>
						<p data-i18n="faq_a2">
							Le proporcionaremos batas, pantuflas y toallas. Solo
							necesita traer ropa cómoda y ganas de relajarse.
						</p>
					</details>
					<details class="faq-item">
						<summary data-i18n="faq_q3"
							>¿Tienen estacionamiento?</summary
						>
						<p data-i18n="faq_a3">
							Sí, contamos con servicio de valet parking y
							espacios designados para nuestros clientes frente al
							spa.
						</p>
					</details>
				</div>
			</div>
		</section>

		<!-- Floating CTA -->
		<a href="#contacto" class="floating-cta shadow">
			<svg
				xmlns="http://www.w3.org/2000/svg"
				width="20"
				height="20"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				class="cta-icon"
				><rect x="3" y="4" width="18" height="18" rx="2" ry="2"
				></rect><line x1="16" y1="2" x2="16" y2="6"></line><line
					x1="8"
					y1="2"
					x2="8"
					y2="6"></line><line x1="3" y1="10" x2="21" y2="10"
				></line></svg
			>
			<span data-i18n="floating_cta">Agenda ahora</span>
		</a>

		</a>

		<!-- Footer -->
		<footer class="footer bg-primary text-white">
			<div class="container footer-content">
				<div class="footer-brand">
					<h3>Oasis Massage & Spa</h3>
					<p data-i18n="footer_desc">
						Relajación profunda, belleza natural.
					</p>
				</div>
				<div class="footer-copy">
					<p data-i18n="footer_copy">
						&copy; Desarrollado por <a href="https://devdiazlabs.com/" target="_blank" class="dev-link">DevDiaz Labs</a>.
					</p>
				</div>
			</div>
		</footer>

