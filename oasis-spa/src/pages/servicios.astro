		<script is:inline>
			const translations = {
				es: {
					nav_home: "Inicio",
					nav_facilities: "Instalaciones",
					nav_contact: "Contacto",
					btn_book: "Reservar",
					srv_hero_title: "Nuestro Menú de Bienestar",
					srv_hero_desc: "Explora nuestro menú completo y diseña tu propia experiencia de relajación. Añade tus servicios favoritos y reserva por WhatsApp.",
					srv_pedicure_name: "Pedicura Terapéutica",
					srv_pedicure_desc: "Tratamiento reparador para pies de 60 min con exfoliación y cuidado profundo.",
					srv_manicure_name: "Manicura Spa",
					srv_manicure_desc: "Cuidado estético y relajante para tus manos con aceites esenciales.",
					srv_massage_facial_name: "Facial Premium",
					srv_massage_facial_desc: "Tratamiento facial avanzado que restaura firmeza y luminosidad con ingredientes de primera.",
					srv_massage_relax_name: "Masaje Relajante",
					srv_massage_relax_desc: "Nuestro ritual estrella de 60 minutos para eliminar todo el estrés acumulado.",
					srv_massage_deep_name: "Masaje de Tejido Profundo",
					srv_massage_deep_desc: "Presión profunda que libera tensiones crónicas y nudos musculares.",
					srv_conotherapy_name: "Masaje Terapéutico",
					srv_conotherapy_desc: "Técnicas especializadas que alivian dolores musculares y mejoran la circulación.",
					srv_apparatus_name: "Envolturas Corporales",
					srv_apparatus_desc: "Tratamientos corporales con productos naturales para desintoxicar y nutrir tu piel.",
					srv_facial_rejuv_name: "Pedicura Reflexológica",
					srv_facial_rejuv_desc: "Pedicura de 70 min con técnicas reflexológicas para equilibrio total.",
					srv_add_btn: "Agregar a la Lista",
					cart_title: "Tu Selección",
					cart_empty: "Tu lista está vacía aún.",
					cart_book_btn: "Reservar por WhatsApp",
					footer_brand: "Oasis Massage & Spa",
					footer_desc: "Relajación profunda, belleza natural.",
					footer_copy: '&copy; Desarrollado por <a href="https://devdiazlabs.com/" target="_blank" class="dev-link">DevDiaz Labs</a>.',
					wa_intro: "Hola, me gustaría reservar los siguientes servicios en Oasis Massage & Spa:",
					cart_remove_tip: "Eliminar de la lista"
				},
				en: {
					nav_home: "Home",
					nav_facilities: "Facilities",
					nav_contact: "Contact",
					btn_book: "Book Now",
					srv_hero_title: "Our Wellness Menu",
					srv_hero_desc: "Explore our full menu and design your own relaxation experience. Add your favorite services and book via WhatsApp.",
					srv_pedicure_name: "Therapeutic Pedicure",
					srv_pedicure_desc: "60 min repairing foot treatment including exfoliation and deep care.",
					srv_manicure_name: "Spa Manicure",
					srv_manicure_desc: "Aesthetic and relaxing care for your hands with essential oils.",
					srv_massage_facial_name: "Premium Facial",
					srv_massage_facial_desc: "Advanced facial treatment that restores firmness and radiance with premium ingredients.",
					srv_massage_relax_name: "Relaxing Massage",
					srv_massage_relax_desc: "Our 60-minute star ritual to eliminate all accumulated stress.",
					srv_massage_deep_name: "Deep Tissue Massage",
					srv_massage_deep_desc: "Deep pressure that releases chronic tension and muscle knots.",
					srv_conotherapy_name: "Therapeutic Massage",
					srv_conotherapy_desc: "Specialized techniques that relieve muscle pain and improve circulation.",
					srv_apparatus_name: "Body Wraps",
					srv_apparatus_desc: "Body treatments with natural products to detoxify and nourish your skin.",
					srv_facial_rejuv_name: "Reflexology Pedicure",
					srv_facial_rejuv_desc: "70 min pedicure with reflexology techniques for total balance.",
					srv_add_btn: "Add to List",
					cart_title: "Your Selection",
					cart_empty: "Your list is empty yet.",
					cart_book_btn: "Book via WhatsApp",
					footer_brand: "Oasis Massage & Spa",
					footer_desc: "Deep relaxation, natural beauty.",
					footer_copy: '&copy; Developed by <a href="https://devdiazlabs.com/" target="_blank" class="dev-link">DevDiaz Labs</a>.',
					wa_intro: "Hello, I would like to book the following services at Oasis Massage & Spa:",
					cart_remove_tip: "Remove from list"
				}
			};

			let currentLang = localStorage.getItem('oasis_lang') || 'es';
			let cart = [];

			function applyLanguage(lang) {
				currentLang = lang;
				localStorage.setItem('oasis_lang', lang);
				
				// Actualizar todos los elementos con data-i18n
				document.querySelectorAll('[data-i18n]').forEach(el => {
					const key = el.getAttribute('data-i18n');
					if (translations[lang][key]) {
						if (el.querySelector('svg')) {
							const svg = el.querySelector('svg').outerHTML;
							el.innerHTML = svg + ' ' + translations[lang][key];
						} else {
							el.innerHTML = translations[lang][key];
						}
					}
				});

				const currentLangLabel = document.getElementById('current-lang');
				if (currentLangLabel) currentLangLabel.textContent = lang.toUpperCase();
				
				const selectedFlag = document.getElementById('selected-flag');
				if (selectedFlag) {
					selectedFlag.src = lang === 'es' 
						? "https://flagcdn.com/w40/mx.png" 
						: "https://flagcdn.com/w40/us.png";
				}

				updateCartUI();
			}

			function initLangSelector() {
				const langBtn = document.querySelector('.lang-btn');
				const langMenu = document.querySelector('.lang-menu');
				const langLinks = document.querySelectorAll('.lang-menu a');

				if (langBtn && langMenu) {
					langBtn.addEventListener('click', (e) => {
						e.stopPropagation();
						langMenu.classList.toggle('show');
					});

					document.addEventListener('click', () => langMenu.classList.remove('show'));

					langLinks.forEach(link => {
						link.addEventListener('click', (e) => {
							e.preventDefault();
							const lang = e.currentTarget.getAttribute('data-lang');
							applyLanguage(lang);
						});
					});
				}
				
				applyLanguage(currentLang);
			}

			function initCart() {
				const savedCart = localStorage.getItem('oasis_cart');
				if (savedCart) {
					try {
						const parsed = JSON.parse(savedCart);
						if (Array.isArray(parsed)) {
							// Filtrar solo items que tengan una clave válida en translations
							// o simplemente limpiar si detectamos formato viejo para evitar inconsistencias
							const hasOldFormat = parsed.some(item => typeof item === 'string' || !translations['es'][item.name]);
							
							if (hasOldFormat) {
								console.log("Detectado formato antiguo o inválido en carrito, limpiando...");
								localStorage.removeItem('oasis_cart');
								cart = [];
							} else {
								cart = parsed;
							}
						}
					} catch (e) {
						cart = [];
					}
				}
				updateCartUI();
			}

			function saveCart() {
				localStorage.setItem('oasis_cart', JSON.stringify(cart));
			}

			function addToCart(serviceKey, serviceImg) {
				const existingItem = cart.find(item => item.name === serviceKey);
				
				if (existingItem) {
					existingItem.quantity = (existingItem.quantity || 0) + 1;
				} else {
					cart.push({
						name: serviceKey,
						image: serviceImg,
						quantity: 1
					});
				}

				saveCart();
				updateCartUI();
				
				const trigger = document.getElementById('cart-trigger');
				if (trigger) {
					trigger.classList.add('pulse');
					setTimeout(() => trigger.classList.remove('pulse'), 400);
				}
			}

			function changeQuantity(index, delta) {
				cart[index].quantity += delta;
				
				if (cart[index].quantity <= 0) {
					removeItem(index);
				} else {
					saveCart();
					updateCartUI();
				}
			}

			function removeItem(index) {
				cart.splice(index, 1);
				saveCart();
				updateCartUI();
			}

			function updateCartUI() {
				const countEl = document.getElementById('cart-count');
				const itemsContainer = document.getElementById('cart-items-container');
				
				if (!countEl || !itemsContainer) return;

				const totalItems = cart.reduce((acc, item) => acc + (parseInt(item.quantity) || 0), 0);
				countEl.innerText = totalItems;
				
				if (cart.length === 0) {
					itemsContainer.innerHTML = `<div style="text-align:center; color: #999; margin-top: 5rem;"><p>${translations[currentLang].cart_empty}</p></div>`;
					return;
				}

				itemsContainer.innerHTML = cart.map((item, index) => {
					const displayName = translations[currentLang][item.name] || item.name;
					const img = item.image || '/images/spa_facilities.png';
					const qty = item.quantity || 1;

					return `
					<div class="cart-item">
						<img src="${img}" class="cart-item-img" alt="${displayName}">
						<div class="cart-item-details">
							<span class="cart-item-name">${displayName}</span>
							<div class="quantity-controls">
								<button class="qty-btn" onclick="changeQuantity(${index}, -1)" aria-label="Restar">-</button>
								<span class="qty-value">${qty}</span>
								<button class="qty-btn" onclick="changeQuantity(${index}, 1)" aria-label="Sumar">+</button>
							</div>
						</div>
							<button class="remove-item" onclick="removeItem(${index})" title="${translations[currentLang].cart_remove_tip}">
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
									<path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
								</svg>
							</button>
					</div>
					`;
				}).join('');
			}

			function toggleCart(forceOpen = false) {
				const panel = document.getElementById('cart-panel');
				const overlay = document.getElementById('cart-overlay');
				
				if (!panel || !overlay) return;
				
				if (forceOpen) {
					panel.classList.add('active');
					overlay.classList.add('active');
				} else {
					panel.classList.toggle('active');
					overlay.classList.toggle('active');
				}
			}

			function reserveOnWhatsApp() {
				if (cart.length === 0) return;

				const intro = translations[currentLang].wa_intro;
				const servicesList = cart.map(item => {
					const name = translations[currentLang][item.name] || item.name;
					return `${item.quantity}x ${name}`;
				}).join("%0A- ");
				
				const message = `${intro}%0A%0A- ${servicesList}%0A%0AMi nombre es: `;
				const waNumber = "523223626879";
				window.open(`https://wa.me/${waNumber}?text=${message}`, '_blank');
			}

			window.addEventListener('DOMContentLoaded', () => {
				initLangSelector();
				initCart();
			});
		</script>

	</body>
</html>
